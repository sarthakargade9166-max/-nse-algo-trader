# .gitignore — Files that should NOT be pushed to GitHub

# Environment variables (contains secrets!)
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# Database files (local SQLite)
data/*.db
data/raw/
data/processed/

# Trained model files (can be large)
models/*.pkl
models/*.json

# OS files
.DS_Store
Thumbs.db

# Streamlit secrets
.streamlit/secrets.toml